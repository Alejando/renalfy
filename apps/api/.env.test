# Test database — usuario de aplicación (sujeto a RLS)
DATABASE_URL=postgresql://renalfy_app:renalfy_app_dev@localhost:5434/renalfy_test

# Migraciones — superusuario (BYPASSRLS implícito)
DATABASE_MIGRATION_URL=postgresql://postgres:postgres@localhost:5434/renalfy_test

JWT_SECRET=test-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

PORT=3019
NODE_ENV=test

# Security
ALLOWED_ORIGINS=http://localhost:3020,https://renalfy.app
