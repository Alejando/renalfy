# Runtime — usuario de aplicación (sujeto a RLS)
DATABASE_URL=postgresql://renalfy_app:change-in-production@localhost:5434/renalfy

# Migraciones — superusuario (BYPASSRLS implícito)
DATABASE_MIGRATION_URL=postgresql://postgres:change-in-production@localhost:5434/renalfy

JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

PORT=3019
NODE_ENV=development
